#!/usr/bin/env bash
set -eu

# Created on: 2026-05-18
# Author: Finn Konrad
# License: MIT
# Description: A Bash script that creates an HTML template file.

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
MINION_PATH="${SCRIPT_DIR}/lib/minion.lib.sh"
INCLUDE_LIST=("error" "warning" "check_content" "check_absent"
    "check_var" "check_path" "check_path_perm" "get_last"
    "init_namespace" "del_namespace" "mktmp_file" "source_file"
)

if [ ! -e "$MINION_PATH" ] || [ -d "$MINION_PATH" ] || [ ! -r "$MINION_PATH" ]; then
    printf "%s\n" "FATAL 1" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" not found." >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$MINION_PATH"

if [ "$(type -t "check_func")" != "function" ] || ! check_func "${INCLUDE_LIST[@]}"; then
    printf "%s\n" "FATAL 2" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" is incomplete." >&2
    exit 1
fi

CONFIG_FILE="${SCRIPT_DIR}/config/mkhtml.conf"
source_file "$CONFIG_FILE" || error "Config \"$(get_last)\" not found." 1

PARAMETERS=("STYLESHEET" "SCRIPT" "AUTHOR" "TITLE"
    "KEYWORDS" "DESCRIPTION" "TYPE" "URL"
    "IMAGE" "FAVICON"
)
check_var "${PARAMETERS[@]}" || error "Parameter \"$(get_last)\" is not set." 2

[ "$#" -ge 1 ] || error "Usage: ${0} [FILENAME(S)]" 3

check_content "$@" || error "Empty file name in parameters." 4
check_absent "$@" || error "\"$(get_last)\" already exists." 5
check_path "$@" || error  "Directory \"$(get_last)\" not found." 6
check_path_perm "wx" "$@" || error "Missing write/execute permission for \"$(get_last)\"." 7

init_namespace
trap del_namespace EXIT
tmp=$(mktmp_file)

cat << END > "$tmp"
<!DOCTYPE html>
<html lang="de">
<head>
    <!-- Browser Window -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="${STYLESHEET}">
    <script type="module" src="${SCRIPT}"></script>

    <!-- SEO -->
    <title>${TITLE}</title>
    <meta name="keywords" content="${KEYWORDS}">
    <meta name="description" content="${DESCRIPTION}">
    <meta name="author" content="${AUTHOR}">

    <!-- Open Graph -->
    <meta property="og:locale" content="de_DE">
    <meta property="og:type" content="${TYPE}">
    <meta property="og:url" content="${URL}">
    <meta property="og:title" content="${TITLE}">
    <meta property="og:description" content="${DESCRIPTION}">
    <meta property="og:image" content="${IMAGE}">

    <!-- Multimedia -->
    <link rel="icon" type="image/svg+xml" href="${FAVICON}">
</head>
<body>

</body>
</html>
END

while [ "$#" -gt 0 ]; do
    if check_absent "$1"; then
        cp "$tmp" "$1"
    else
        warning "Skipped duplicate parameter \"$(get_last)\"."
    fi
    shift
done

exit 0
