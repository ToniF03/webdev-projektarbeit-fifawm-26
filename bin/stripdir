#!/usr/bin/env bash
set -eu

# Created on: 2026-05-19
# Author: Finn Konrad
# License: MIT
# Description: A Bash script that strips all EXIF ​​data from files in a directory and its subdirectories.

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
MINION_PATH="${SCRIPT_DIR}/lib/minion.lib.sh"
INCLUDE_LIST=("error" "warning" "info" "check_dep"
    "check_empty" "check_dir" "check_perm" "check_size"
    "get_last" "init_namespace" "del_namespace" "mktmp_file"
)

if [ ! -e "$MINION_PATH" ] || [ -d "$MINION_PATH" ] || [ ! -r "$MINION_PATH" ]; then
    printf "%s\n" "FATAL 1" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" not found." >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$MINION_PATH"

if [ "$(type -t "check_func")" != "function" ] || ! check_func "${INCLUDE_LIST[@]}"; then
    printf "%s\n" "FATAL 2" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" is incomplete." >&2
    exit 1
fi

DEPENDENCIES=("exiftool")
check_dep "${DEPENDENCIES[@]}" || error "Command \"$(get_last)\" not found." 1

[ "$#" -ge 1 ] || error "Usage: ${0} [DIRNAME(S)]" 2

check_empty "$@" && error "Empty directory name in parameters." 3
check_dir "$@" || error "Directory \"$(get_last)\" not found." 4
check_perm "rwx" "$@" || error "Missing read/write/execute permission for directory \"$(get_last)\"." 5

init_namespace
trap del_namespace EXIT
results=$(mktmp_file)

skip_counter="0"
while [ "$#" -gt 0 ]; do

    dir="$1"
    : > "$results"

    find "$dir" -type f 2>/dev/null > "$results"
    skip_counter=$(( skip_counter += $(find "$dir" -type f 2>&1 >/dev/null | wc -l) ))

    if check_size "$dir"; then
        while IFS= read -r file; do
            exiftool -all= -overwrite_original "$file" >/dev/null 2>&1 || skip_counter=$((skip_counter += 1))
        done <"$results"
    else
        warning "Directory \"$(get_last)\" is empty."
    fi

    shift
done

if [ "$skip_counter" -eq 1 ]; then
    info "${skip_counter} file/subdirectory was not stripped due to its format/permissions."
elif [ "$skip_counter" -gt 1 ]; then
    info "${skip_counter} files/subdirectories were not stripped due to their format/permissions."
fi

exit 0
