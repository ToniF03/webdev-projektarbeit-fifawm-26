#!/usr/bin/env bash
set -eu

# Created on: 2026-05-21
# Author: Finn Konrad
# License: MIT
# Description: A Bash script that checks for the presence of a list of dependencies.

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
MINION_PATH="${SCRIPT_DIR}/lib/minion.lib.sh"
INCLUDE_LIST=("error" "warning" "check_dep" "check_var"
    "check_content" "source_file" "get_last"
)

if [ ! -e "$MINION_PATH" ] || [ -d "$MINION_PATH" ] || [ ! -r "$MINION_PATH" ]; then
    printf "%s\n" "FATAL 1" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" not found." >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$MINION_PATH"

if [ "$(type -t "check_func")" != "function" ] || ! check_func "${INCLUDE_LIST[@]}"; then
    printf "%s\n" "FATAL 2" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" is incomplete." >&2
    exit 1
fi

CONFIG_FILE="${SCRIPT_DIR}/config/checkdeps.conf"
source_file "$CONFIG_FILE" || error "Config \"$(get_last)\" not found." 1

PARAMETERS=("DEPENDENCIES")
check_var "${PARAMETERS[@]}" || error "Parameter \"$(get_last)\" is not set." 2

check_content "${DEPENDENCIES[@]}" || error "Empty dependency name in dependencies list." 3

failed="false"
check_dep "${DEPENDENCIES[@]}" || { warning "Command \"$(get_last)\" not found."; failed="true"; }

[ "$failed" = "true" ] && error "Missing dependencies." 4
exit 0
