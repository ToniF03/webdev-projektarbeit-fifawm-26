#!/usr/bin/env bash
set -eu

# Created on: 2026-05-18
# Author: Finn Konrad
# License: MIT
# Description: A Bash script that creates a CSS template file.

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
MINION_PATH="${SCRIPT_DIR}/lib/minion.lib.sh"
INCLUDE_LIST=("error" "warning" "check_content" "check_absent"
    "check_var" "check_path" "check_path_perm" "get_last"
    "init_namespace" "del_namespace" "mktmp_file" "source_file"
)

if [ ! -e "$MINION_PATH" ] || [ -d "$MINION_PATH" ] || [ ! -r "$MINION_PATH" ]; then
    printf "%s\n" "FATAL 1" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" not found." >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$MINION_PATH"

if [ "$(type -t "check_func")" != "function" ] || ! check_func "${INCLUDE_LIST[@]}"; then
    printf "%s\n" "FATAL 2" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" is incomplete." >&2
    exit 1
fi

CONFIG_FILE="${SCRIPT_DIR}/config/mkcss.conf"
source_file "$CONFIG_FILE" || error "Config \"$(get_last)\" not found." 1

PARAMETERS=("DATE" "AUTHOR" "LICENSE" "DESCRIPTION"
    "SMOOTH_SCROLLING" "SET_BORDER_BOX" "RESET_PADDING" "RESET_MARGIN"
    "TEMPLATE_FOCUS" "TEMPLATE_SELECTION" "TEMPLATE_IMPORT" "TEMPLATE_MEDIA_QUERY"
    "TEMPLATE_GLOBAL_VARIABLE"
)
check_var "${PARAMETERS[@]}" || error "Parameter \"$(get_last)\" is not set." 2

[ "$#" -ge 1 ] || error "Usage: ${0} [FILENAME(S)]" 3

check_content "$@" || error "Empty file name in parameters." 4
check_absent "$@" || error "\"$(get_last)\" already exists." 5
check_path "$@" || error  "Directory \"$(get_last)\" not found." 6
check_path_perm "wx" "$@" || error "Missing write/execute permission for \"$(get_last)\"." 7

init_namespace
trap del_namespace EXIT
tmp=$(mktmp_file)
: > "$tmp"

write_content (){
    if [ "$#" -gt 0 ]; then
        printf "%s\n" "$1" >> "$tmp"
    else
        cat >> "$tmp"
    fi
}

[ "$TEMPLATE_IMPORT" = "true" ] && cat << END | write_content
@import url('URL_PLACEHOLDER');

END

cat << END | write_content
/*
* Created on: ${DATE}
* Author(s): ${AUTHOR}
* License: ${LICENSE}
* Description: ${DESCRIPTION}
*/

END

[ "$TEMPLATE_GLOBAL_VARIABLE" = "true" ] && cat << END | write_content
:root {--variable: 42;}

END

[ "$SMOOTH_SCROLLING" = "true" ] && cat << END | write_content
html {scroll-behavior: smooth;}

END

if [ "$SET_BORDER_BOX" = "true" ] || [ "$RESET_PADDING" = "true" ] || [ "$RESET_MARGIN" = "true" ]; then
    write_content '*,'
    write_content '*::before,'
    write_content '*::after {'
    [ "$SET_BORDER_BOX" = "true" ] && write_content '    box-sizing: border-box;'
    [ "$RESET_PADDING" = "true" ] && write_content '    padding: 0;'
    [ "$RESET_MARGIN" = "true" ] && write_content '    margin: 0;'
    write_content '}'
    write_content ''
fi

[ "$TEMPLATE_SELECTION" = "true" ] && cat << END | write_content
::selection {--variable: 42;}

END

[ "$TEMPLATE_FOCUS" = "true" ] && cat << END | write_content
:focus {--variable: 42;}

END

[ "$TEMPLATE_MEDIA_QUERY" = "true" ] && cat << END | write_content
@media all and (width >= 0) {
    :root {--variable: 42;}
}

END

while [ "$#" -gt 0 ]; do
    if check_absent "$1"; then
        cp "$tmp" "$1"
    else
        warning "Skipped duplicate parameter \"$(get_last)\"."
    fi
    shift
done

exit 0
