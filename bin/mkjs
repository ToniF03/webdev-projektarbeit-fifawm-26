#!/usr/bin/env bash
set -eu

# Created on: 2026-05-18
# Author: Finn Konrad
# License: MIT
# Description: A Bash script that creates a JS template file.

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
MINION_PATH="${SCRIPT_DIR}/lib/minion.lib.sh"
INCLUDE_LIST=("error" "check_dep" "check_perm" "get_last")

if [ ! -e "$MINION_PATH" ] || [ -d "$MINION_PATH" ] || [ ! -r "$MINION_PATH" ]; then
    printf "%s\n" "FATAL 1" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" not found." >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$MINION_PATH"

if [ "$(type -t "check_func")" != "function" ] || ! check_func "${INCLUDE_LIST[@]}"; then
    printf "%s\n" "FATAL 2" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" is incomplete." >&2
    exit 1
fi

CONFIG_FILE="${SCRIPT_DIR}/config/mkjs.conf"
source_file "$CONFIG_FILE" || error "Config \"$(get_last)\" not found." 1

PARAMETERS=("DATE" "AUTHOR" "LICENSE" "DESCRIPTION"
    "TEMPLATE_CLASS" "TEMPLATE_FETCH_API" "TEMPLATE_DISPATCH_EVENT" "TEMPLATE_EVENT_LISTENER"
    "TEMPLATE_VITEST_TEST"
)
check_var "${PARAMETERS[@]}" || error "Parameter \"$(get_last)\" is not set." 2

[ "$#" -ge 1 ] || error "Usage: ${0} [FILENAME(S)]" 3

check_content "$@" || error "Empty file name in parameters." 4
check_absent "$@" || error "\"$(get_last)\" already exists." 5
check_path "$@" || error  "Directory \"$(get_last)\" not found." 6
check_path_perm "wx" "$@" || error "Missing write/execute permission for \"$(get_last)\"." 7

init_namespace
trap del_namespace EXIT
tmp=$(mktmp_file)
: > "$tmp"

cat << END >> "$tmp"
/*
* Created on: ${DATE}
* Author(s): ${AUTHOR}
* License: ${LICENSE}
* Description: ${DESCRIPTION}
*/

END

[ "$TEMPLATE_VITEST_TEST" = "true" ] && cat << END >> "$tmp"
import { describe, beforeEach, afterEach, test, expect } from 'vitest';

describe('Test group', () => {

    let value = 42;

    beforeEach(() => {
        console.log('Runs before each test().');
    })
    afterEach(() => {
        console.log('Runs after each test().');
    })

    test('Test case', () => {
        expect(value).toBe(42);
    })
})

END

[ "$TEMPLATE_CLASS" = "true" ] && cat << END >> "$tmp"
export class Template {

    #privateMember;

    constructor(parameter = 42) {
        this.#privateMember = parameter;
    }

    static staticMethod (){
        console.log('42');
    }
    #privateMethod (){
        console.log(this.#privateMember);
    }
    publicMethod (){
        this.#privateMethod();
    }
}

END

[ "$TEMPLATE_EVENT_LISTENER" = "true" ] && cat << END >> "$tmp"
document.addEventListener('click', () => {
    console.log('Event triggered.');
})

END

[ "$TEMPLATE_FETCH_API" = "true" ] && cat << END >> "$tmp"
async function fetchData (url){
    try {
        const response = await fetch(url);
        if (!response.ok){
            throw new Error(\`Server Error. [CODE:\${response.status}]\`);
        }
        const data = await response.json();
        return data;
    }
    catch (msg){
        console.error(msg);
    }
}
fetchData('URL_PLACEHOLDER');

END

[ "$TEMPLATE_DISPATCH_EVENT" = "true" ] && cat << END >> "$tmp"
function dispatchCustomEvent(name){
    window.dispatchEvent(new CustomEvent(name));
}
dispatchCustomEvent('EVENT_PLACEHOLDER');

END

while [ "$#" -gt 0 ]; do
    if check_absent "$1"; then
        cp "$tmp" "$1"
    else
        warning "Skipped duplicate parameter \"$(get_last)\"."
    fi
    shift
done

exit 0
