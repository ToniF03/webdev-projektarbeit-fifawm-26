#!/usr/bin/env bash
set -eu

# Created on: 2026-05-20
# Author: Finn Konrad
# License: MIT
# Description: A Bash script that creates an archive in a target folder from any number of source files.

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
MINION_PATH="${SCRIPT_DIR}/lib/minion.lib.sh"
INCLUDE_LIST=("error" "warning" "check_dep" "check_var"
    "check_file" "check_dir" "check_perm" "check_empty"
    "check_content" "check_absent" "check_exists" "get_last"
    "init_namespace" "del_namespace" "mktmp_dir" "mktmp_name"
    "source_file"
)

if [ ! -e "$MINION_PATH" ] || [ -d "$MINION_PATH" ] || [ ! -r "$MINION_PATH" ]; then
    printf "%s\n" "FATAL 1" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" not found." >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$MINION_PATH"

if [ "$(type -t "check_func")" != "function" ] || ! check_func "${INCLUDE_LIST[@]}"; then
    printf "%s\n" "FATAL 2" >&2
    printf "%s\n" "\"$(basename "$MINION_PATH")\" is incomplete." >&2
    exit 1
fi

DEPENDENCIES=("tar" "zip")
check_dep "${DEPENDENCIES[@]}" || error "Command \"$(get_last)\" not found." 1

[ "$#" -ge 1 ] || error "Usage: ${0} [TARGET_DIRECTORY(S)]" 2

check_content "$@" || error "Empty directory name in parameters." 3
check_dir "$@" || error "Directory $(get_last) not found." 4
check_perm "wx" "$@" || error "Missing write/execute permission for directory \"$(get_last)\"." 5
TARGET_DIRS=()
for DIR in "$@"; do
    TARGET_DIRS+=("$(realpath "$DIR")")
done

cd "$SCRIPT_DIR"

CONFIG_FILE="${SCRIPT_DIR}/config/bundler.conf"
source_file "$CONFIG_FILE" || error "Config \"$(get_last)\" not found." 6

PARAMETERS=("ROOT_DIR" "SRC_FILES" "BUNDLE_NAME" "GEN_DIR"
    "GEN_TGZ" "GEN_ZIP"
)
check_var "${PARAMETERS[@]}" || error "Parameter \"$(get_last)\" is not set." 7

check_dir "$ROOT_DIR" || error "Directory $(get_last) not found." 8
check_perm "wx" "$ROOT_DIR" || error "Missing write/execute permission for directory \"$(get_last)\"." 9
cd "$ROOT_DIR"

for file in "${SRC_FILES[@]}"; do

    check_empty "$file" && error "Empty file name in source files list." 10
    check_exists "$file" || error "File \"$(get_last)\" not found." 11

    if check_file "$file"; then
        check_perm "r" "$file" || error "Missing read permission for file \"$(get_last)\"." 12
    elif check_dir "$file"; then
        check_perm "rx" "$file" || error "Missing read/execute permission for directory \"$(get_last)\"." 13

        if [ -n "$(find "$file" \( -type f ! -readable -o -type d \( ! -readable -o ! -executable \) \) -print -quit)" ]; then
            error "Missing read/execute permission for files/directories inside directory \"$(get_last)\"." 14
        fi
    else
        error "\"$(get_last)\" has an unknown file type." 15
    fi
done

for TARGET_DIR in "${TARGET_DIRS[@]}"; do
    dir_path="${TARGET_DIR}/${BUNDLE_NAME}"
    tgz_path="${TARGET_DIR}/${BUNDLE_NAME}.tar.gz"
    zip_path="${TARGET_DIR}/${BUNDLE_NAME}.zip"

    check_absent "$dir_path" "$tgz_path" "$zip_path" || error "\"$(get_last)\" already exists." 16
done

init_namespace
trap del_namespace EXIT
tmp_dir=$(mktmp_dir)
tmp_tgz=$(mktmp_name)
tmp_zip=$(mktmp_name)

cp -r --parent "${SRC_FILES[@]}" "$tmp_dir"
tar -czf "$tmp_tgz" "${SRC_FILES[@]}"
zip -r "$tmp_zip" "${SRC_FILES[@]}" >/dev/null

for TARGET_DIR in "${TARGET_DIRS[@]}"; do
    dir_path="${TARGET_DIR}/${BUNDLE_NAME}"
    tgz_path="${TARGET_DIR}/${BUNDLE_NAME}.tar.gz"
    zip_path="${TARGET_DIR}/${BUNDLE_NAME}.zip"

    if check_absent "$dir_path" "$tgz_path" "$zip_path"; then
        [ "$GEN_DIR" = "true" ] && cp -r "$tmp_dir" "$dir_path"
        [ "$GEN_TGZ" = "true" ] && cp "$tmp_tgz" "$tgz_path"
        [ "$GEN_ZIP" = "true" ] && cp "$tmp_zip" "$zip_path"
    else
        warning "Skipped duplicate parameter \"$(get_last)\"."
    fi
done

exit 0
