#!/usr/bin/env bash
set -eu

# Created on: 2026-05-20
# Author: Finn Konrad
# License: MIT
# Description: A Bash script that creates an archive in a target folder from any number of source files.

error (){
    printf "%s\n" "ERROR ${2:-1}" >&2
    printf "%s\n" "$1" >&2
    exit "${2:-1}"
}

var_check (){
    if [ ! -v "$1" ] || [ -z "${!1}" ]; then
        error "Variable \"$1\" is not set." 3
    fi
}

check_dependency (){
    if ! command -v "$1" >/dev/null 2>&1; then
        error "Command \"${1}\" not found." 1
    fi
}

dir_check (){
    if [ ! -e "$1" ]; then
        error "Directory \"${1}\" not found." 4
    elif [ ! -d "$1" ]; then
        error "\"${1}\" is not a directory." 5
    elif [ ! -w "$1" ]; then
        error "Missing write permission for \"${1}\"." 6
    fi
}

tmp_names=()
# shellcheck disable=SC2317
clear_tmp_files (){
    local tmp_name
    for tmp_name in "${tmp_names[@]}"; do
        rm -rf "$tmp_name"
    done
}
trap 'clear_tmp_files' EXIT

dependencies=("tar" "zip")

for dependency in "${dependencies[@]}"; do
    check_dependency "$dependency"
done

conf_dir="$(dirname "$0")/config"
conf_file="${conf_dir}/bundler.conf"

if [ ! -f "$conf_file" ]; then
    error "Config \"${conf_file}\" not found." 2
fi

# shellcheck source=/dev/null
source "$conf_file"

var_arr=("ROOT_DIR" "SRC_FILES" "BUNDLE_NAME" "GEN_DIR" "GEN_TGZ" "GEN_ZIP")

for var in "${var_arr[@]}"; do
    var_check "$var"
done

if [ $# -ne 1 ]; then
    error "Usage: bundler [TARGET_DIRECTORY]" 14
fi

dir_check "$1"
TARGET_DIR="$(realpath "$1")"

SCRIPT_DIR="$(dirname "${BASH_SOURCE[0]}")"
cd "$SCRIPT_DIR"

dir_check "$ROOT_DIR"
ROOT_DIR="$(dirname "$ROOT_DIR")"
cd "$ROOT_DIR"

for file in "${SRC_FILES[@]}"; do

    if [ -z "$file" ]; then
        error "Empty file name in source files list." 7
    elif [ ! -e "$file" ]; then
        error "File \"${file}\" not found." 8
    elif [ ! -d "$file" ]; then

        if [ ! -r "$file" ]; then
            error "Missing read permission for file \"${file}\"." 9
        fi

    elif [ -d "$file" ]; then

        if [ ! -r "$file" ]; then
            error "Missing read permission for directory \"${file}\"." 10
        elif [ ! -x "$file" ]; then
            error "Missing execute permission for directory \"${file}\"." 11
        elif [ -n "$(find "$file" \( -type f ! -readable -o -type d \( ! -readable -o ! -executable \) \) -print -quit)" ]; then
            error "Missing read/execute permission for files/directories inside directory \"${file}\"." 12
        fi

    else
        error "\"${file}\" has an unknown file type." 13
    fi

done

tmp_dir=$(mktemp -d)
tmp_names+=("$tmp_dir")

tmp_tgz=$(mktemp)
tmp_names+=("$tmp_tgz")

tmp_zip=$(mktemp)
tmp_names+=("$tmp_zip")

rm -f "$tmp_tgz" "$tmp_zip"

dir_path="${TARGET_DIR}/${BUNDLE_NAME}"
tgz_path="${TARGET_DIR}/${BUNDLE_NAME}.tar.gz"
zip_path="${TARGET_DIR}/${BUNDLE_NAME}.zip"

if [ "$GEN_DIR" = "true" ]; then
    if [ -e "$dir_path" ]; then
        error "\"${dir_path}\" already exists." 15
    fi

    cp -r --parent "${SRC_FILES[@]}" "$tmp_dir"
    mv "$tmp_dir" "$dir_path"
fi

if [ "$GEN_TGZ" = "true" ]; then
    if [ -e "$tgz_path" ]; then
        error "\"${tgz_path}\" already exists." 15
    fi

    tar -czf "$tmp_tgz" "${SRC_FILES[@]}"
    mv "$tmp_tgz" "$tgz_path"
fi

if [ "$GEN_ZIP" = "true" ]; then
    if [ -e "$zip_path" ]; then
        error "\"${zip_path}\" already exists." 15
    fi

    zip -r "$tmp_zip" "${SRC_FILES[@]}" >/dev/null
    mv "$tmp_zip" "$zip_path"
fi

exit 0
